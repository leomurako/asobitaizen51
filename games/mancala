<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>マンカラ - Premium Clone</title>
    <style>
        :root {
            --bg-color: #0f1612;
            --board-color: radial-gradient(circle, #b07e53 50%, #82532a 100%);
            --board-border: #563313;
            --pit-bg: #3c2009;
            --text-color: #f4ede4;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            font-family: -apple-system, BlinkMacSystemFont, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            color: var(--text-color);
            user-select: none;
        }

        h1 {
            margin: 0 0 5px;
            font-size: 24px;
            letter-spacing: 3px;
        }

        #status {
            font-size: 16px;
            margin-bottom: 25px;
            font-weight: 600;
            color: #d4a373;
            height: 24px;
            letter-spacing: 1px;
        }

        /* ボード */
        .mancala-board {
            background: var(--board-color);
            border: 8px solid var(--board-border);
            border-radius: 40px;
            box-shadow: 0 16px 40px rgba(0,0,0,0.6), inset 0 2px 4px rgba(255,255,255,0.2);
            padding: 30px;
            display: flex;
            align-items: center;
            gap: 20px;
            max-width: 820px;
            width: 90%;
            box-sizing: border-box;
        }

        /* ストア */
        .store-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 80px;
        }

        .store-label {
            font-size: 11px;
            margin-bottom: 8px;
            opacity: 0.6;
            font-weight: bold;
            letter-spacing: 1px;
        }

        .store {
            width: 70px;
            height: 200px;
            background-color: var(--pit-bg);
            border-radius: 35px;
            position: relative;
            box-shadow: inset 0 10px 15px rgba(0,0,0,0.7), 0 2px 2px rgba(255,255,255,0.1);
        }

        /* ポケット */
        .pits-container {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .row {
            display: flex;
            justify-content: space-around;
        }

        .pit-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .pit-label {
            font-size: 10px;
            opacity: 0.5;
            margin-top: 6px;
            margin-bottom: 6px;
            font-weight: bold;
        }

        .pit {
            width: 68px;
            height: 68px;
            background-color: var(--pit-bg);
            border-radius: 50%;
            position: relative;
            cursor: pointer;
            box-shadow: inset 0 8px 12px rgba(0,0,0,0.7), 0 2px 2px rgba(255,255,255,0.1);
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.2s;
        }

        /* 手番のハイライトとホバー */
        .active-player .pit {
            box-shadow: inset 0 8px 12px rgba(0,0,0,0.7), 0 0 12px rgba(255, 255, 255, 0.25);
        }

        .active-player .pit:hover {
            transform: scale(1.1);
            box-shadow: inset 0 8px 12px rgba(0,0,0,0.7), 0 0 15px rgba(212, 163, 115, 0.8);
        }

        /* 石のバッジ */
        .seed-count {
            position: absolute;
            bottom: -5px;
            right: -5px;
            background-color: rgba(0, 0, 0, 0.85);
            color: #fff;
            border-radius: 12px;
            padding: 2px 7px;
            font-size: 11px;
            font-weight: bold;
            pointer-events: none;
            border: 1px solid rgba(255,255,255,0.15);
            z-index: 10;
        }

        /* 散らばるビーズ */
        .marbles-layer {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0; left: 0;
            pointer-events: none;
        }

        .marble {
            position: absolute;
            width: 11px;
            height: 11px;
            border-radius: 50%;
            box-shadow: 1px 2px 3px rgba(0,0,0,0.6);
            background: radial-gradient(circle at 4px 4px, #ffffff, var(--marble-color, #ff595e));
        }

        button {
            margin-top: 30px;
            padding: 10px 25px;
            font-size: 14px;
            font-weight: 600;
            background-color: #26352d;
            color: var(--text-color);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            cursor: pointer;
            box-shadow: 0 4px 8px rgba(0,0,0,0.3);
            transition: background 0.2s, transform 0.1s;
        }

        button:hover {
            background-color: #32463b;
        }

        button:active {
            transform: scale(0.97);
        }
    </style>
</head>
<body>

    <h1>MANCALA</h1>
    <div id="status">Player 1 のターン</div>

    <div class="mancala-board">
        <div class="store-container">
            <span class="store-label">PLAYER 2</span>
            <div class="store" id="pit-13">
                <div class="marbles-layer"></div>
                <div class="seed-count">0</div>
            </div>
        </div>

        <div class="pits-container">
            <!-- プレイヤー2（上行：右から左へ反時計回り） -->
            <div class="row" id="row-p2">
                <div class="pit-wrapper">
                    <div class="pit" id="pit-12"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                    <span class="pit-label">P2-6</span>
                </div>
                <div class="pit-wrapper">
                    <div class="pit" id="pit-11"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                    <span class="pit-label">P2-5</span>
                </div>
                <div class="pit-wrapper">
                    <div class="pit" id="pit-10"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                    <span class="pit-label">P2-4</span>
                </div>
                <div class="pit-wrapper">
                    <div class="pit" id="pit-9"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                    <span class="pit-label">P2-3</span>
                </div>
                <div class="pit-wrapper">
                    <div class="pit" id="pit-8"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                    <span class="pit-label">P2-2</span>
                </div>
                <div class="pit-wrapper">
                    <div class="pit" id="pit-7"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                    <span class="pit-label">P2-1</span>
                </div>
            </div>

            <!-- プレイヤー1（下行：左から右へ反時計回り） -->
            <div class="row" id="row-p1">
                <div class="pit-wrapper">
                    <span class="pit-label">P1-1</span>
                    <div class="pit" id="pit-0"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                </div>
                <div class="pit-wrapper">
                    <span class="pit-label">P1-2</span>
                    <div class="pit" id="pit-1"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                </div>
                <div class="pit-wrapper">
                    <span class="pit-label">P1-3</span>
                    <div class="pit" id="pit-2"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                </div>
                <div class="pit-wrapper">
                    <span class="pit-label">P1-4</span>
                    <div class="pit" id="pit-3"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                </div>
                <div class="pit-wrapper">
                    <span class="pit-label">P1-5</span>
                    <div class="pit" id="pit-4"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                </div>
                <div class="pit-wrapper">
                    <span class="pit-label">P1-6</span>
                    <div class="pit" id="pit-5"><div class="marbles-layer"></div><span class="seed-count">4</span></div>
                </div>
            </div>
        </div>

        <div class="store-container">
            <span class="store-label">PLAYER 1</span>
            <div class="store" id="pit-6">
                <div class="marbles-layer"></div>
                <div class="seed-count">0</div>
            </div>
        </div>
    </div>

    <button onclick="resetGame()">最初からやり直す</button>

    <script>
        let board = [];
        let currentPlayer = 1;
        let gameOver = false;

        const marbleColors = ['#ff595e', '#ffca3a', '#8ac926', '#1982c4', '#6a4c93'];

        function initGame() {
            board = [4, 4, 4, 4, 4, 4, 0, 4, 4, 4, 4, 4, 4, 0];
            currentPlayer = 1;
            gameOver = false;
            updateUI();
        }

        // ビーズ配置描画
        function renderMarbles(pitIdx, count) {
            const pitEl = document.getElementById(`pit-${pitIdx}`);
            const layer = pitEl.querySelector('.marbles-layer');
            layer.innerHTML = '';

            const isStore = (pitIdx === 6 || pitIdx === 13);
            const visualLimit = Math.min(count, 14);

            for (let i = 0; i < visualLimit; i++) {
                const marble = document.createElement('div');
                marble.className = 'marble';

                const angle = Math.random() * Math.PI * 2;
                let x, y;

                if (isStore) {
                    const radiusX = Math.random() * 15;
                    const radiusY = Math.random() * 65;
                    x = 29 + Math.cos(angle) * radiusX;
                    y = 94 + Math.sin(angle) * radiusY;
                } else {
                    const radius = Math.random() * 19;
                    x = 28 + Math.cos(angle) * radius;
                    y = 28 + Math.sin(angle) * radius;
                }

                marble.style.left = `${x}px`;
                marble.style.top = `${y}px`;
                marble.style.setProperty('--marble-color', marbleColors[(pitIdx + i) % marbleColors.length]);
                
                layer.appendChild(marble);
            }
        }

        function updateUI() {
            for (let i = 0; i < 14; i++) {
                const pitEl = document.getElementById(`pit-${i}`);
                pitEl.querySelector('.seed-count').innerText = board[i];
                renderMarbles(i, board[i]);
            }

            const rowP1 = document.getElementById('row-p1');
            const rowP2 = document.getElementById('row-p2');

            if (gameOver) {
                rowP1.classList.remove('active-player');
                rowP2.classList.remove('active-player');
                return;
            }

            if (currentPlayer === 1) {
                rowP1.classList.add('active-player');
                rowP2.classList.remove('active-player');
                document.getElementById('status').innerText = "Player 1 のターン";
            } else {
                rowP1.classList.remove('active-player');
                rowP2.classList.add('active-player');
                document.getElementById('status').innerText = "Player 2 のターン";
            }
        }

        function makeMove(pitIdx) {
            if (gameOver) return;

            if (currentPlayer === 1 && (pitIdx < 0 || pitIdx > 5)) return;
            if (currentPlayer === 2 && (pitIdx < 7 || pitIdx > 12)) return;
            if (board[pitIdx] === 0) return;

            let seeds = board[pitIdx];
            board[pitIdx] = 0;
            let current = pitIdx;

            while (seeds > 0) {
                current = (current + 1) % 14;

                if (currentPlayer === 1 && current === 13) continue;
                if (currentPlayer === 2 && current === 6) continue;

                board[current]++;
                seeds--;
            }

            const ownStore = (currentPlayer === 1) ? 6 : 13;
            let extraTurn = false;

            if (current === ownStore) {
                extraTurn = true;
            } else {
                const isOwnSide = (currentPlayer === 1 && current >= 0 && current <= 5) ||
                                  (currentPlayer === 2 && current >= 7 && current <= 12);
                const opposite = 12 - current;

                if (isOwnSide && board[current] === 1 && board[opposite] > 0) {
                    const captured = board[current] + board[opposite];
                    board[current] = 0;
                    board[opposite] = 0;
                    board[ownStore] += captured;
                }
            }

            checkGameOver();

            if (!gameOver && !extraTurn) {
                currentPlayer = (currentPlayer === 1) ? 2 : 1;
            } else if (!gameOver && extraTurn) {
                document.getElementById('status').innerText = `Player ${currentPlayer} のターン（もう一回！）`;
            }

            updateUI();
        }

        function checkGameOver() {
            const p1Empty = board.slice(0, 6).every(s => s === 0);
            const p2Empty = board.slice(7, 13).every(s => s === 0);

            if (p1Empty || p2Empty) {
                gameOver = true;

                if (p1Empty) {
                    for (let i = 7; i <= 12; i++) {
                        board[13] += board[i];
                        board[i] = 0;
                    }
                }
                if (p2Empty) {
                    for (let i = 0; i <= 5; i++) {
                        board[6] += board[i];
                        board[i] = 0;
                    }
                }

                const s1 = board[6];
                const s2 = board[13];
                let msg = "";

                if (s1 > s2) msg = `ゲーム終了！ ${s1} 対 ${s2} で Player 1 の勝ち！`;
                else if (s2 > s1) msg = `ゲーム終了！ ${s2} 対 ${s1} で Player 2 の勝ち！`;
                else msg = `ゲーム終了！ ${s1} 対 ${s2} で引き分け！`;

                document.getElementById('status').innerText = msg;
            }
        }

        function resetGame() {
            initGame();
        }

        for (let i = 0; i < 14; i++) {
            if (i !== 6 && i !== 13) {
                document.getElementById(`pit-${i}`).addEventListener('click', () => makeMove(i));
            }
        }

        initGame();
    </script>
</body>
</html>
